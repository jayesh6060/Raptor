# Set default behavior to handle line endings automatically
* text=auto

# Force LF for all source files to ensure consistency across OS
*.tsx text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf

# Force CRLF for certain Windows-specific files if any exist (none here yet)

# Binary files - don't touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.webp binary
*.svg binary
